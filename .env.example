# Bible Canvas — 환경변수 템플릿
# 이 파일을 .env.local로 복사하고 값을 채워주세요

# ─── Unsplash (무료 이미지) ───────────────────────────────────
# https://unsplash.com/developers 에서 발급
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ─── Anthropic (말씀 추천 AI) ─────────────────────────────────
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ─── Vercel Blob (이미지 업로드 임시 저장) ────────────────────
# Vercel 대시보드 > Storage > Blob 에서 발급
BLOB_READ_WRITE_TOKEN=vercel_blob_your_token_here

# ─── 공개 URL ────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── 카카오 공유 ─────────────────────────────────────────────
# https://developers.kakao.com 에서 JavaScript 키 발급
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_js_key_here

# ─── (Phase 2) DALL-E / Stable Diffusion ────────────────────
# OPENAI_API_KEY=sk-your_openai_key_here
